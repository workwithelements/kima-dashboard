NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shopify sync (used by scripts/sync-shopify.ts)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your-access-token-here

# Apify (used by the Organic Social tab)
#   APIFY_TOKEN          — read token for fetching dataset items from scheduled runs
#   APIFY_WEBHOOK_SECRET — shared secret Apify passes back in the webhook URL;
#                          generate any random string and paste the same value
#                          into the Apify Task's webhook URL.
APIFY_TOKEN=apify_api_your-token-here
APIFY_WEBHOOK_SECRET=generate-a-random-string-here
