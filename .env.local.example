NEXT_PUBLIC_SUPABASE_URL=https://djghsnesigcvafhykpqj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Meta Marketing API token — required for creative previews (/api/ad-preview
# resolves each ad's creative through the Graph API; /api/thumbnail uses it
# to refresh expired thumbnail URLs). Same token the kima-sync repo uses.
META_ACCESS_TOKEN=your-meta-access-token-here

# Shopify sync (used by scripts/sync-shopify.ts)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your-access-token-here

# Apify token (used by scripts/sync-instagram-tagged.ts for the Organic Social tab)
APIFY_TOKEN=apify_api_your-token-here
